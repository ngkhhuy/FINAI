files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/01_backend_logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/app.log
      /tmp/logs/finai-*.log

  "/etc/nginx/conf.d/elasticbeanstalk/00_static_proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Gzip compression
      gzip on;
      gzip_comp_level 4;
      gzip_types text/plain text/css text/javascript application/json application/javascript application/x-javascript;

      # Static assets: add cache headers then proxy through to Express
      # Do NOT use try_files here — files live in backend/dist/public which is
      # not the Nginx document root. Express serves them directly.
      location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        proxy_pass http://nodejs;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
      }

      # NOTE: Do NOT add a location / block here.
      # The default EB proxy already has it; a duplicate would conflict.
      # Express handles SPA fallback via app.get("*") → index.html.

container_commands:
  01_fix_permissions:
    command: |
      chmod -R 755 /var/app/current/backend/dist/public || true
