files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/01_backend_logs.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/app.log
      /tmp/logs/finai-*.log

  "/etc/nginx/conf.d/elasticbeanstalk/00_static_proxy.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      # Gzip compression
      gzip on;
      gzip_comp_level 4;
      gzip_types text/plain text/css text/javascript application/json application/javascript application/x-javascript;

      # Cache static assets
      location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
      }

      # SPA fallback - route all unmatched requests to index.html for frontend
      location / {
        try_files $uri $uri/ /index.html;
      }

container_commands:
  01_fix_permissions:
    command: |
      chmod -R 755 /var/app/current/backend/dist/public || true
