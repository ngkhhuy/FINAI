files:
  "/opt/elasticbeanstalk/tasks/bundlelogs.d/01_custom_log.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      /var/log/app-access.log

option_settings:
  # Redirect HTTP to HTTPS
  aws:elbv2:listener:default:
    Protocol: HTTPS
    SSLPolicy: ELBSecurityPolicy-TLS-1-2-2017-01
    SSLCertificateArn: arn:aws:acm:REGION:ACCOUNT_ID:certificate/CERTIFICATE_ID
  
  # HealthCheck configuration
  aws:elasticbeanstalk:environment:process:default:
    HealthCheckPath: /health
    HealthyThresholdCount: 3
    UnhealthyThresholdCount: 5
    Timeout: 5
    Interval: 30
    Port: 80
    Protocol: HTTP

  # Enable gzip compression
  aws:elasticbeanstalk:xray:
    XRayEnabled: "false"

commands:
  00_pre_deploy:
    command: |
      echo "Pre-deployment started at $(date)" >> /var/log/app-deploy.log
